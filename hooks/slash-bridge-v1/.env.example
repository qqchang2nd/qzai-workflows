# slash-bridge-v1 示例配置（脱敏）
# 位置：hooks/slash-bridge-v1/.env
# 注意：.env 含敏感信息，务必加入 .gitignore，不要提交。

# 监听端口（默认 8787）
PORT=8787

# 用于请求体 HMAC 校验：X-Hub-Signature-256
SLASH_BRIDGE_HOOK_SECRET=__REPLACE_ME__

# 允许的仓库白名单（fail-closed）
# 格式："owner/repo" 或 "owner/repo:installationId"，多个用逗号分隔
SLASH_BRIDGE_ALLOWED_REPOS=owner/repo

# SQLite 数据库路径（相对 hooks/slash-bridge-v1 工作目录）
SLASH_BRIDGE_DB_PATH=./slash-bridge-v1.sqlite

# 可选：额外允许的 authorAssociation（逗号分隔），默认仅允许 OWNER/MEMBER/COLLABORATOR
# SLASH_BRIDGE_AUTHOR_ASSOC_EXTRA_ALLOW=CONTRIBUTOR

# 可选：限流窗口与次数
# SLASH_BRIDGE_RATE_WINDOW_MS=60000
# SLASH_BRIDGE_RATE_MAX=5

# GitHub 鉴权（二选一）：
# A) 本地调试可用（不推荐生产）：直接提供 GITHUB_TOKEN
# GITHUB_TOKEN=__REPLACE_ME__

# B) 推荐：GitHub App（需要 installationId）
SLASH_BRIDGE_GH_APP_ID=__REPLACE_ME__
SLASH_BRIDGE_GH_APP_PRIVATE_KEY_PATH=/absolute/path/to/github-app.private-key.pem
# 可选：如果你希望固定 installationId（否则由每次请求 payload.installationId 提供）
# SLASH_BRIDGE_GH_APP_INSTALLATION_ID=__REPLACE_ME__

# C) 支持多 Agent 专属身份（可选覆盖）
# 为特定的 routed agent 配置专属的 GitHub 身份，若未配置则自动 fallback 到上述全局配置。
# 命名格式：在原变量名后追加 __<AGENTID大写>。
# 例：给 agentId "luxiaofeng" 配置专属身份：
# GITHUB_TOKEN__LUXIAOFENG=__REPLACE_ME__
# SLASH_BRIDGE_GH_APP_ID__LUXIAOFENG=__REPLACE_ME__
# SLASH_BRIDGE_GH_APP_PRIVATE_KEY_PATH__LUXIAOFENG=/absolute/path/to/luxiaofeng-app.private-key.pem
# SLASH_BRIDGE_GH_APP_INSTALLATION_ID__LUXIAOFENG=__REPLACE_ME__
